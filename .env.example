# --- Postgres (solo red interna Docker) ---
POSTGRES_USER=admosa
POSTGRES_PASSWORD=REEMPLAZAR
POSTGRES_DB=admosa_test

# --- Sesiones (mínimo 32 caracteres) ---
SESSION_SECRET=REEMPLAZAR

# --- Frontend (Firebase Hosting) ---
FRONTEND_URL=https://proyecto.web.app

# --- Cookies cross-domain (Firebase HTTPS → backend HTTPS) ---
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

# --- Opcionales ---
SESSION_MAX_AGE_MS=14400000
LOGIN_RATE_LIMIT_MAX=500
MAX_FILE_SIZE_BYTES=52428800
BACKEND_PORT=4000

# --- Desarrollo local (ng serve) — descomenta y comenta el bloque de arriba ---
# FRONTEND_URL=http://localhost:4200
# SESSION_COOKIE_SAMESITE=strict
# SESSION_COOKIE_SECURE=false

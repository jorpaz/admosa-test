# Copiar a .env: cp .env.example .env
# Postgres local (docker compose up -d postgres)
DATABASE_URL=postgresql://admosa:admosa@localhost:5432/admosa_test

# Mínimo 32 caracteres
SESSION_SECRET=dev-secret-cambiar-en-produccion-minimo-32-chars

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:4200
STORAGE_PATH=./storage
MAX_FILE_SIZE_BYTES=52428800

# Login: intentos permitidos por ventana (dev=200 por defecto)
LOGIN_RATE_LIMIT_MAX=200
